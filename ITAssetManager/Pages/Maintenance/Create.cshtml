@page
@model ITAssetManager.Pages.Maintenance.CreateModel
@{
    ViewData["Title"] = "ثبت تعمیر / مشکل";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-tools me-2"></i>ثبت تعمیر / مشکل
            </div>
            <div class="card-body">
                @if (Model.Asset != null)
                {
                    <div class="alert alert-secondary mb-4 py-2 d-flex align-items-center gap-2">
                        <i class="bi bi-cpu"></i>
                        <strong>@Model.Asset.Name</strong>
                        @if (!string.IsNullOrEmpty(Model.Asset.PropertyTag))
                        {
                            <span class="text-muted">(@Model.Asset.PropertyTag)</span>
                        }
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Log.AssetId" />

                    @if (Model.Asset == null)
                    {
                        <div class="mb-3">
                            <label class="form-label">تجهیز</label>
                            <select asp-for="Log.AssetId" asp-items="Model.AssetList" class="form-select">
                                <option value="">انتخاب تجهیز...</option>
                            </select>
                        </div>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">نوع</label>
                            <select asp-for="Log.Type" class="form-select">
                                <option value="1">تعمیر</option>
                                <option value="2">نگهداری پیشگیرانه</option>
                                <option value="3">ارتقا</option>
                                <option value="4">بازرسی</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">تکنسین</label>
                            <input asp-for="Log.TechnicianName" class="form-control" placeholder="نام تکنسین یا شرکت سرویس" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">توضیح مشکل / کار <span class="text-danger">*</span></label>
                            <textarea asp-for="Log.Description" class="form-control" rows="3"
                                placeholder="شرح مشکل یا کاری که انجام شد..."></textarea>
                            <span asp-validation-for="Log.Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">تاریخ شروع</label>
                            <input asp-for="Log.StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">تاریخ پایان</label>
                            <input asp-for="Log.EndDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">هزینه (تومان)</label>
                            <input asp-for="Log.Cost" type="number" class="form-control" placeholder="0" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">نتیجه / راه‌حل</label>
                            <textarea asp-for="Log.Resolution" class="form-control" rows="2"
                                placeholder="در صورت حل‌شدن مشکل، راه‌حل را بنویسید..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-2">
                                <input asp-for="Log.IsResolved" type="checkbox" class="form-check-input" />
                                <label asp-for="Log.IsResolved" class="form-check-label">مشکل حل شده</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>ذخیره
                        </button>
                        <a href="@(Model.Asset != null ? $"/Assets/Details/{Model.Asset.Id}" : "/Maintenance")"
                           class="btn btn-outline-secondary">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

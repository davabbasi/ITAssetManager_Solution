@page
@model ITAssetManager.Pages.Maintenance.IndexModel
@{
    ViewData["Title"] = "تعمیرات";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">تعمیرات و نگهداری</h5>
    <a href="/Maintenance/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>ثبت تعمیر
    </a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="text-warning fs-4"><i class="bi bi-clock-history"></i></div>
            <div class="fw-bold fs-5">@Model.OpenCount</div>
            <small class="text-muted">در جریان</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="text-success fs-4"><i class="bi bi-check-circle"></i></div>
            <div class="fw-bold fs-5">@Model.ResolvedCount</div>
            <small class="text-muted">حل‌شده</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="text-primary fs-4"><i class="bi bi-currency-dollar"></i></div>
            <div class="fw-bold fs-5">@Model.TotalCost.ToString("N0")</div>
            <small class="text-muted">مجموع هزینه (تومان)</small>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><i class="bi bi-tools me-2"></i>لیست تعمیرات</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th>تجهیز</th>
                        <th>نوع</th>
                        <th>توضیح</th>
                        <th>تکنسین</th>
                        <th>هزینه</th>
                        <th>وضعیت</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Logs)
                    {
                        <tr>
                            <td><small>@m.StartDate.ToString("yy/MM/dd")</small></td>
                            <td>
                                <a href="/Assets/Details/@m.AssetId" class="text-decoration-none fw-medium">
                                    @m.Asset?.Name
                                </a>
                            </td>
                            <td>
                                <small>
                                    @(m.Type switch {
                                        MaintenanceType.Repair => "تعمیر",
                                        MaintenanceType.Preventive => "پیشگیرانه",
                                        MaintenanceType.Upgrade => "ارتقا",
                                        _ => "بازرسی"
                                    })
                                </small>
                            </td>
                            <td><small>@(m.Description.Length > 40 ? m.Description[..40] + "..." : m.Description)</small></td>
                            <td><small>@(m.TechnicianName ?? "-")</small></td>
                            <td><small>@(m.Cost.HasValue ? m.Cost.Value.ToString("N0") : "-")</small></td>
                            <td>
                                <span class="badge @(m.IsResolved ? "badge-active" : "badge-repair")">
                                    @(m.IsResolved ? "حل شده" : "در جریان")
                                </span>
                            </td>
                            <td>
                                <a href="/Maintenance/Edit/@m.Id" class="btn btn-xs btn-outline-secondary" title="ویرایش">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>.btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; }</style>

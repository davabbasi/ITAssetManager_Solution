@page
@model ITAssetManager.Pages.Admin.SpecificationIndex
@{
    ViewData["Title"] = "مشخصات فنی";
}


@if (Model.SpecificationList!=null && Model.SpecificationList.Count>0)
{
    <!-- جدول مشخصات فنی -->
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-tag me-2"></i>مشخصات فنی</span>
            <a asp-page="/Admin/SpecDefinitionCreate"  class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>ایجاد مشخصه جدید
            </a>          
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>نام مشخصه</th>
                            <th>ترتیب</th>
                            <th>تعداد مقادیر</th>
                            <th style="width:120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var spec in Model.SpecificationList)
                        {
                            var selected = Model.SelectedSpecId == spec.Id;
                            <tr class="@(selected ? "table-primary" : "")">
                                <td class="fw-medium">@spec.Name</td>
                                <td><small class="text-muted">@spec.SortOrder</small></td>
                                <td>
                                    <a href="?SelectedCategoryId=selectedSpecId=@spec.Id"
                                       class="badge @(selected ? "bg-primary" : "bg-light text-dark") text-decoration-none">
                                        @spec.SpecValues.Count مقدار
                                    </a>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                    <a href="/Admin/SpecificationValueCreate?specId=@spec.Id"
                                        class="btn btn-xs btn-outline-success" title="افزودن مقدار">
                                        <i class="bi bi-plus"></i>

                                        </a>
                                    <a href="/Admin/SpecificationEdit?specId=@spec.Id"
                                           class="btn btn-xs btn-outline-primary" title="ویرایش">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-page-handler="DeleteSpec"
                                              onsubmit="return confirm('این مشخصه و تمام مقادیرش حذف شود؟')">
                                            <input type="hidden" name="specId" value="@spec.Id" />
                                            <input type="hidden" name="categoryId" value="@Model.SelectedSpecId" />
                                            <button type="submit" class="btn btn-xs btn-outline-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

        </div>
    </div>

    <!-- جدول مقادیر -->
    @* @if (Model.SelectedSpecId.HasValue)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">

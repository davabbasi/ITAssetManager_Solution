@page
@model ITAssetManager.Pages.Admin.SpecDefinitionCreateModel
@{
    ViewData["Title"] = "ایجاد مشخصه جدید";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle me-2"></i>ایجاد مشخصه جدید
                <small class="text-muted me-2">— @Model.CategoryName</small>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    <div class="mb-3">
                        <label class="form-label">نام مشخصه <span class="text-danger">*</span></label>
                        <input name="name" class="form-control" required
                            placeholder="مثلاً: مارک، رم، هارد1، سایز" autofocus />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">ترتیب نمایش</label>
                        <input name="sortOrder" type="number" value="0" class="form-control" style="max-width:120px;" />
                        <small class="text-muted">عدد کمتر = نمایش اول</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>ذخیره
                        </button>
                        <a href="/Admin/Specs?categoryId=@Model.CategoryId" class="btn btn-outline-secondary">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@page
@model ITAssetManager.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "مدیریت کاربران";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible">
        @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <!-- فرم ایجاد کاربر -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-person-plus me-2"></i>کاربر جدید</div>
            <div class="card-body">
                <form method="post" asp-page-handler="CreateUser">
                    <div class="mb-3">
                        <label class="form-label">ایمیل <span class="text-danger">*</span></label>
                        <input name="email" type="email" class="form-control" required placeholder="user@company.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">رمز عبور <span class="text-danger">*</span></label>
                        <input name="password" type="password" class="form-control" required placeholder="حداقل ۶ کاراکتر" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">نقش</label>
                        <select name="role" class="form-select">
                            <option value="User">کاربر عادی</option>
                            <option value="Admin">مدیر (Admin)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-plus me-1"></i>ایجاد کاربر
                    </button>
                </form>
            </div>
        </div>

        <!-- تغییر رمز -->
        <div class="card">
            <div class="card-header"><i class="bi bi-key me-2"></i>تغییر رمز کاربر</div>
            <div class="card-body">
                <form method="post" asp-page-handler="ChangePassword">
                    <div class="mb-3">
                        <label class="form-label">کاربر</label>
                        <select name="userId" class="form-select form-select-sm">
                            @foreach (var u in Model.Users)
                            {
                                <option value="@u.Id">@u.Email</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">رمز جدید</label>
                        <input name="newPassword" type="password" class="form-control form-control-sm" placeholder="حداقل ۶ کاراکتر" />
                    </div>
                    <button type="submit" class="btn btn-outline-warning btn-sm w-100">تغییر رمز</button>
                </form>
            </div>
        </div>
    </div>

    <!-- لیست کاربران -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-people me-2"></i>کاربران سیستم (@Model.Users.Count نفر)</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr><th>ایمیل</th><th>نقش</th><th>عملیات</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            var isAdmin = Model.UserRoles.ContainsKey(user.Id) &&
                                          Model.UserRoles[user.Id].Contains("Admin");
                            <tr>
                                <td>
                                    <i class="bi bi-person-circle me-1 text-muted"></i>
                                    @user.Email
                                    @if (user.Email == User.Identity?.Name)
                                    {
                                        <span class="badge bg-secondary ms-1" style="font-size:0.65rem;">شما</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(isAdmin ? "bg-primary" : "bg-secondary")">
                                        @(isAdmin ? "Admin" : "User")
                                    </span>
                                </td>
                                <td>
                                    @if (user.Email != User.Identity?.Name)
                                    {
                                        <div class="d-flex gap-1">
                                            <form method="post" asp-page-handler="ToggleRole">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-xs @(isAdmin ? "btn-outline-secondary" : "btn-outline-primary")">
                                                    @(isAdmin ? "تبدیل به User" : "تبدیل به Admin")
                                                </button>
                                            </form>
                                            <form method="post" asp-page-handler="DeleteUser"
                                                onsubmit="return confirm('آیا مطمئن هستید؟')">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-xs btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <small class="text-muted">-</small>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>.btn-xs { padding: 0.15rem 0.5rem; font-size: 0.75rem; }</style>

@page
@model ITAssetManager.Pages.Admin.ViewDepartmentsModel
@{
    ViewData["Title"] = "واحدها";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-building me-2"></i>لیست واحدها</span>
        <small class="text-muted">اطلاعات از سیستم پرسنلی</small>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>نام واحد</th></tr></thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    <tr><td class="fw-medium">@dept.Name</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
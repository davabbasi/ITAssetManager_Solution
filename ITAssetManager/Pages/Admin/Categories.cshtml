@page
@model ITAssetManager.Pages.Admin.CategoriesModel
@{
    ViewData["Title"] = "دسته‌بندی تجهیزات";
}

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                @(Model.Input.Id > 0 ? "ویرایش دسته‌بندی" : "افزودن دسته‌بندی")
            </div>
            <div class="card-body">
                <form method="post">
                    @if (Model.Input.Id>0)
                    {
                        <input type="hidden" asp-for="Input.Id" />
                    }
                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label"> <span class="text-danger"> * </span> نام دسته بندی</label>
                        <input asp-for="Input.Name" class="form-control" required />
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Type" class="form-label">  <span class="text-danger">*</span> نوع دسته بندی</label>
                        
                        <select asp-for="Input.Type" class="form-select">
                            <option value="1" selected="@(Model.Input.Type == 1)">کالای برچسبی</option>
                            <option value="2" selected="@(Model.Input.Type == 2)">قطعات نصبی</option>
                            <option value="3" selected="@(Model.Input.Type == 3)">مواد مصرفی</option>
                        </select>
                    </div>
                 @*    <div class="mb-3">
                        <label class="form-label">آیکون Bootstrap</label>
                        <div class="input-group">
                            <span class="input-group-text" id="iconPreview">
                                <i class="bi @(Model.EditIcon ?? "bi-box")"></i>
                            </span>
                            <input name="icon" id="iconInput" value="@(Model.EditIcon ?? "bi-box")"
                                class="form-control" placeholder="مثلاً: bi-laptop" />
                        </div>
                        <small class="text-muted">
                            از <a href="https://icons.getbootstrap.com" target="_blank">Bootstrap Icons</a> انتخاب کنید
                        </small>
                    </div> *@

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <input asp-for="Input.Description"  class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">ذخیره</button>
                    @if (Model.Input.Id > 0)
                    {
                        <a href="/Admin/Categories" class="btn btn-outline-secondary btn-sm ms-1">انصراف</a>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">دسته‌بندی‌ها</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>نام</th>
                            <th>توضیح</th>
                            <th>نوع</th>
                            <th>تعداد</th>
                            <th></th>
                        </tr>
                     </thead>
                    <tbody>
                        @foreach (var cat in Model.Categories)
                        {
                            <tr>
                                
                                <td class="fw-medium">@cat.Name</td>
                                <td><small class="text-muted">@(cat.Description ?? "-")</small></td>

                                <td>
                                    @{
                                        var (typeBadge, typeLabel) = cat.Type switch
                                        {
                                            AssetCategoryType.Tagged => ("bg-primary", "برچسبی"),
                                            AssetCategoryType.Installed => ("bg-warning text-dark", "نصبی"),
                                            AssetCategoryType.Consumable => ("bg-success", "مصرفی"),
                                            _ => ("bg-secondary", "نامشخص")
                                        };
                                    }
                                    <span class="badge @typeBadge">@typeLabel</span>
                                </td>


                                <td><span class="badge bg-light text-dark">@cat.Assets.Count</span></td>
                                <td>
                                    <a asp-page="/Admin/Categories" asp-route-Id="@cat.Id" class="btn btn-xs btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@* <script>
    document.getElementById('iconInput')?.addEventListener('input', function() {
        document.querySelector('#iconPreview i').className = 'bi ' + this.value;
    });
</script> *@


@page
@model ITAssetManager.Pages.Admin.SpecValueEditModel
@{
    ViewData["Title"] = "ویرایش مقدار";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil me-2"></i>ویرایش مقدار
                <small class="text-muted me-2">— @Model.SpecName</small>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" name="id" value="@Model.ValueId" />
                    <input type="hidden" name="specId" value="@Model.SpecId" />
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    <div class="mb-3">
                        <label class="form-label">مقدار <span class="text-danger">*</span></label>
                        <input name="value" value="@Model.Value" class="form-control" required autofocus />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">ترتیب نمایش</label>
                        <input name="sortOrder" type="number" value="@Model.SortOrder"
                            class="form-control" style="max-width:120px;" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>ذخیره
                        </button>
                        <a href="/Admin/Specs?categoryId=@Model.CategoryId&selectedSpecId=@Model.SpecId"
                           class="btn btn-outline-secondary">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

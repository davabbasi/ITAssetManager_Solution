@page
@model ITAssetManager.Pages.PurchaseRequests.IndexModel
@{
	ViewData["Title"] = "درخواست‌های خرید";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h5 class="mb-0 fw-bold">درخواست‌های خرید</h5>
	<small class="text-muted">@Model.Result.VwPurchaseRequests.Count() رکورد</small>
</div>

<!-- فرم جستجو -->
<div class="card mb-3">
	<div class="card-body py-2">
		<form class="row g-2 align-items-end">
			<div class="col-md-3">
				<label class="form-label mb-1 small">شماره سفارش</label>
				<input type="text" name="orderNo" 
					   class="form-control form-control-sm" placeholder="شماره سفارش..." />
			</div>
			<div class="col-md-3">
				<label class="form-label mb-1 small">شماره رسید</label>
				<input type="text" name="serial"
					   class="form-control form-control-sm" placeholder="شماره رسید..." />
			</div>
			<div class="col-md-3">
				<label class="form-label mb-1 small">شرح کالا</label>
				<input type="text" name="description" 
					   class="form-control form-control-sm" placeholder="جستجو در شرح کالا..." />
			</div>
			<div class="col-md-3 d-flex gap-1">
				<button type="submit" class="btn btn-primary btn-sm flex-fill">
					<i class="bi bi-search me-1"></i>جستجو
				</button>
				<a href="/PurchaseRequests" class="btn btn-outline-secondary btn-sm">
					<i class="bi bi-x"></i>
				</a>
			</div>
		</form>
	</div>
</div>

<!-- جدول -->
<div class="card">
	<div class="card-body p-0">
		@if (!Model.Result.VwPurchaseRequests.Any())
		{
			<div class="text-center text-muted py-5">
				<i class="bi bi-inbox fs-2"></i>
				<p class="mt-2">رکوردی یافت نشد</p>
			</div>
		}
		else
		{
			<div class="table-responsive">
				<table class="table table-hover table-sm mb-0">
					<thead>
						<tr>
							<th>ش. درخواست</th>
							<th>تاریخ درخواست</th>
							<th>ش. سفارش</th>
							<th>تاریخ سفارش</th>
							<th>کد کالا</th>
							<th>شرح کالا</th>
							<th>واحد</th>
							<th class="text-center">تعداد درخواستی</th>
							<th class="text-center">تعداد خریداری</th>
							<th class="text-center">دریافتی</th>

							<th class="text-end">نرخ خرید</th>
							<th class="text-end">پرداختی</th>
							<th>ش. رسید</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model.Result.VwPurchaseRequests)
						{
							<tr>
								<td><small>@(item.RequestNo ?? "_")</small></td>
								<td><small>@(item.RequestDate ?? 0)</small></td>
								<td><small class="fw-medium">@(item.OrderNo ?? "-")</small></td>
								<td><small>@(item.OrderDate ?? 0)</small></td>
								<td><small class="font-monospace">@(item.ItemCode ?? "-")</small></td>
								<td>
									<small title="@item.FarsiDesc">
										@(item.FarsiDesc?.Length > 30 ? item.FarsiDesc[..30] + "..." : item.FarsiDesc ?? "-")
									</small>
								</td>
								<td><small>@(item.CurrentUnit ?? "-")</small></td>
								<td class="text-center"><small>@item.ConfirmedQuantity</small></td>
								<td class="text-center"><small>@item.Quantity</small></td>
								<td class="text-center">
									<small class="@(item.ReceivedQuantity > 0 ? "text-success fw-medium" : "")">
										@item.ReceivedQuantity
									</small>
								</td>
								<td class="text-end"><small>@item.PayRate?.ToString("N0")</small></td>
								<td class="text-end">
									<small class="fw-medium">@item.PayPass?.ToString("N0")</small>
								</td>
								<td><small class="font-monospace">@(item.Serial ?? "-")</small></td>
							</tr>
						}
					</tbody>
				</table>
			</div>

			<!-- صفحه‌بندی -->
			  @if (Model.Result.PageCount > 1)
            {
                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                    <small class="text-muted">
                        نمایش رکورد های

						@(((Model.Result.CurrentPage) - 1) * Model.Take + 1)
                        تا

						@(Math.Min(Model.Result.CurrentPage * Model.Take, Model.TotalRecord))

@* 						@(Model.Result.CurrentPage* Model.Take)
 *@
						از

						@Model.TotalRecord

						رکورد
                    </small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">

                           @*  <li class="page-item @(Model.Result.CurrentPage <= 1 ? "disabled" : "")">
								<a class="page-link" href="?currentPage=@(Model.Result.CurrentPage - 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                            @if (Model.Result.CurrentPage > 3)
                            {
                                <li class="page-item">
									<a class="page-link" href="?currentPage=">1</a>
                                </li>
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            } *@

							@for(int i = 1; i <= Model.Result.PageCount+1; i++)
							{
								<li class="page-item @(i == Model.Result.CurrentPage ? "active" : "")">
									<a class="page-link" href="?currentPage=@i">@i</a>
								</li>
							}




							@* @for (int i = Math.Max(1, Model.Result.PageCount - 2); i <= Math.Min(Model.Result.PageCount, Model.Result.CurrentPage + 2); i++)
                            {
                                <li class="page-item @(i == Model.Result.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="?page=@i">@i</a>
                                </li>
                            } *@
@* 
							@if (Model.Result.CurrentPage < Model.Result.PageCount - 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                <li class="page-item">
									<a class="page-link" href="?currentPage=@Model.Result.PageCount">@Model.Result.PageCount</a>
                                </li>
                            } *@

                          @*   <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
								<a class="page-link" href="?currentPage=@(Model.Page + 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li> *@

                        </ul>
                    </nav>
                </div>
            }
		}
	</div>
</div>
@page
@model ITAssetManager.Pages.Reports.ScrappedModel
@{
    ViewData["Title"] = "تجهیزات اسقاطی";
}

<h5 class="mb-3 fw-bold"><i class="bi bi-trash3 me-2"></i>تجهیزات اسقاطی و نیاز به تعویض</h5>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="text-secondary fs-4"><i class="bi bi-trash3"></i></div>
            <div class="fw-bold fs-5">@Model.Scrapped.Count</div>
            <small class="text-muted">اسقاط شده</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="text-danger fs-4"><i class="bi bi-x-octagon"></i></div>
            <div class="fw-bold fs-5">@Model.Faulty.Count</div>
            <small class="text-muted">معیوب (نیاز به تعویض)</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="text-warning fs-4"><i class="bi bi-tools"></i></div>
            <div class="fw-bold fs-5">@Model.UnderRepair.Count</div>
            <small class="text-muted">در تعمیر</small>
        </div>
    </div>
</div>

@if (Model.Scrapped.Any())
{
    <div class="card mb-3">
        <div class="card-header"><i class="bi bi-trash3 me-2 text-secondary"></i>تجهیزات اسقاط شده</div>
        <div class="card-body p-0">
            @await Html.PartialAsync("_AssetTable", Model.Scrapped)
        </div>
    </div>
}

@if (Model.Faulty.Any())
{
    <div class="card mb-3">
        <div class="card-header text-danger"><i class="bi bi-x-octagon me-2"></i>تجهیزات معیوب</div>
        <div class="card-body p-0">
            @await Html.PartialAsync("_AssetTable", Model.Faulty)
        </div>
    </div>
}

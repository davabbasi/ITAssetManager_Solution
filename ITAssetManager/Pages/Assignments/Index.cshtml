@page
@model ITAssetManager.Pages.Assignments.IndexModel
@{
    ViewData["Title"] = "تاریخچه جابجایی‌ها";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">جابجایی تجهیزات</h5>
    <a href="/Assignments/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>ثبت جابجایی
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="search" value="@Model.Search"
                    class="form-control form-control-sm"
                    placeholder="جستجو در تجهیزات، کارمندان..." />
            </div>
            <div class="col-md-2">
                <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                    class="form-control form-control-sm" placeholder="از تاریخ" />
            </div>
            <div class="col-md-2">
                <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                    class="form-control form-control-sm" placeholder="تا تاریخ" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search"></i> جستجو
                </button>
            </div>
            <div class="col-md-2">
                <a href="/Assignments" class="btn btn-outline-secondary btn-sm w-100">پاک‌کردن</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header"><i class="bi bi-arrow-left-right me-2"></i>@Model.Assignments.Count جابجایی</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th>تجهیز</th>
                        <th>از</th>
                        <th></th>
                        <th>به</th>
                        <th>مکان</th>
                        <th>دلیل</th>
                        <th>ثبت‌کننده</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Assignments)
                    {
                        <tr>
                            <td><small>@a.AssignedAt.ToString("yy/MM/dd HH:mm")</small></td>
                            <td>
                                <a href="/Assets/Details/@a.AssetId" class="text-decoration-none fw-medium">
                                    @a.Asset?.Name
                                </a>
                                @if (!string.IsNullOrEmpty(a.Asset?.PropertyTag))
                                {
                                    <br /><small class="text-muted">@a.Asset.PropertyTag</small>
                                }
                            </td>
                            <td><small class="text-muted">@(a.FromEmployeeName ?? a.FromDepartmentName ?? "-")</small></td>
                            <td><i class="bi bi-arrow-left text-primary"></i></td>
                            <td><small class="fw-medium">@(a.ToEmployeeName ?? a.ToDepartmentName ?? "تخصیص‌نیافته")</small></td>
                            <td><small class="text-muted">@(a.ToLocation ?? "-")</small></td>
                            <td><small>@(a.Reason ?? "-")</small></td>
                            <td><small class="text-muted">@a.AssignedBy</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

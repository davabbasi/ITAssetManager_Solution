@page
@model ITAssetManager.Pages.ErrorModel
@{
    ViewData["Title"] = "خطا";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle text-danger" style="font-size:4rem;"></i>
    <h3 class="mt-3">خطایی رخ داد</h3>
    <p class="text-muted">متأسفانه مشکلی پیش آمده است.</p>
    @if (Model.RequestId != null)
    {
        <p class="text-muted small">شناسه درخواست: <code>@Model.RequestId</code></p>
    }
    <a href="/" class="btn btn-primary mt-2">بازگشت به داشبورد</a>
</div>

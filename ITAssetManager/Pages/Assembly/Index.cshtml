@page
@model ITAssetManager.Pages.Assembly.IndexModel
@{
    ViewData["Title"] = "اسمبل سیستم";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">سیستم‌های اسمبل‌شده</h5>
    <a href="/Assembly/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>اسمبل سیستم جدید
    </a>
</div>

<div class="card">
    <div class="card-header"><i class="bi bi-pc-display me-2"></i>@Model.Items.Count سیستم</div>
    <div class="card-body p-0">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-2"></i>
                <p class="mt-2">سیستمی اسمبل نشده</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>شماره</th>
                        <th>تاریخ اسمبل</th>
                        <th>شماره اموال</th>
                        <th>مدل</th>
                        <th>تعداد قطعات فعال</th>
                        <th>تخصیص</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pc in Model.Items)
                    {
                        <tr>
                            <td><span class="badge bg-primary">#@pc.AssemblyNumber</span></td>
                            <td><small>@pc.CreatedAt.ToString("yyyy/MM/dd")</small></td>
                            <td><small>@(pc.PropertyTag ?? "-")</small></td>
                            <td><small>@(pc.Model ?? "-")</small></td>
                            <td><span class="badge bg-light text-dark">@pc.Components.Count(c => c.RemovedAt == null) قطعه</span></td>
                            <td><small>@(pc.EmployeeName ?? pc.DepartmentName ?? "تخصیص‌نیافته")</small></td>
                            <td>
                                <a href="/Assembly/Details/@pc.Id" class="btn btn-xs btn-outline-secondary">
                                    <i class="bi bi-eye"></i> جزئیات
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<style>.btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; }</style>
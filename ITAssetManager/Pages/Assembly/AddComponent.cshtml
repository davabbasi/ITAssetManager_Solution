@page
@model ITAssetManager.Pages.Assembly.AddComponentModel
@{
    ViewData["Title"] = "افزودن قطعه";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle me-2"></i>افزودن قطعه به سیستم #@Model.PcAsset.AssemblyNumber
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" name="pcId" value="@Model.PcAsset.Id" />

                    <div class="mb-3">
                        <label class="form-label">دسته‌بندی قطعه</label>
                        <select id="categorySelect" class="form-select">
                            <option value="">انتخاب دسته‌بندی...</option>
                            @foreach (var cat in Model.InstalledCategories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">قطعه آزاد</label>
                        <select name="componentId" id="componentSelect" class="form-select" disabled required>
                            <option value="">ابتدا دسته‌بندی را انتخاب کنید</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>افزودن
                        </button>
                        <a href="/Assembly/Details/@Model.PcAsset.Id" class="btn btn-outline-secondary">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('categorySelect').addEventListener('change', function () {
            const categoryId = this.value;
            const sel = document.getElementById('componentSelect');
            sel.innerHTML = '<option>در حال بارگذاری...</option>';
            sel.disabled = true;

            if (!categoryId) {
                sel.innerHTML = '<option value="">ابتدا دسته‌بندی را انتخاب کنید</option>';
                return;
            }

            fetch('/Api/FreeComponents?categoryId=' + categoryId)
                .then(r => r.json())
                .then(items => {
                    if (!items || items.length === 0) {
                        sel.innerHTML = '<option value="">قطعه آزادی موجود نیست</option>';
                        return;
                    }
                    sel.innerHTML = '<option value="">انتخاب قطعه...</option>' +
                        items.map(i => `<option value="${i.id}">${i.name} ${i.propertyTag ? '(' + i.propertyTag + ')' : ''}</option>`).join('');
                    sel.disabled = false;
                });
        });
    </script>
}